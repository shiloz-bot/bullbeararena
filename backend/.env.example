# BullBearArena Environment Variables

# LLM Configuration (required)
# Supported providers: openai, anthropic, ollama, openrouter, zai (Zhipu/GLM)
LLM_PROVIDER=zai
LLM_MODEL=glm-4-flash
LLM_API_KEY=your-api-key-here

# Optional: Custom base URL (default for zai is https://api.z.ai/api/paas/v4)
# LLM_BASE_URL=

# Optional: Debug mode
# DEBUG=true
