# Environment variables for BullBearArena

# LLM Configuration (required)
# Supported providers: openai, anthropic, ollama, openrouter, zai (Zhipu GLM)
LLM_PROVIDER=zai
LLM_MODEL=glm-4-flash
LLM_API_KEY=your-glm-api-key-here

# Optional: Custom LLM base URL
# For Zhipu GLM, we auto-configure: https://open.bigmodel.cn/api/paas/v4
# LLM_BASE_URL=

# Optional: Debug mode
# DEBUG=true
